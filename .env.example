# Telegram Bot API Token (получить у @BotFather)
TELEGRAM_BOT_TOKEN=

# Google Gemini API Key (получить на https://aistudio.google.com/)
GEMINI_API_KEY=

# DeepSeek API Key (получить на https://platform.deepseek.com/)
DEEPSEEK_API_KEY=
DEEPSEEK_API_URL=https://api.deepseek.com/v1/chat/completions

# Пароль для защиты административных эндпоинтов (придумайте свой)
ADMIN_PASSWORD=your_admin_password_here

# (Опционально, только для Vercel KV) — подключаются автоматически при привязке Storage
# KV_REST_API_URL=
